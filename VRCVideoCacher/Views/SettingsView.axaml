<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VRCVideoCacher.ViewModels"
             xmlns:models="using:VRCVideoCacher.Models"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:loc="using:CodingSeb.Localization.Avalonia"
             x:Class="VRCVideoCacher.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, Auto" Margin="10">
            <TextBlock Text="{loc:Tr Settings}" FontSize="24" FontWeight="Bold"/>

            <!-- Status Message -->
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Margin="15,0" VerticalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="#81C784"/>

            <Button Grid.Column="2" Command="{Binding ResetToDefaultsCommand}" Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="Undo" Width="16" Height="16"/>
                    <TextBlock Text="{loc:Tr Reset}"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Command="{Binding SaveSettingsCommand}" Classes="accent">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <mi:MaterialIcon Kind="ContentSave" Width="16" Height="16"/>
                    <TextBlock Text="{loc:Tr Save}"/>
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="20" Margin="10">

            <!-- General Settings -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Tr General}" FontWeight="SemiBold" FontSize="16"/>

                    <StackPanel Spacing="5">
                        <TextBlock Text="{loc:Tr Language}"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageOption}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding CloseToTray}" Content="{loc:Tr CloseToTray}"/>
                    <CheckBox IsChecked="{Binding StartMinimized}" Content="{loc:Tr StartMinimized}"/>
                </StackPanel>
            </Border>

            <!-- Server Settings -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Tr ServerSettings}" FontWeight="SemiBold" FontSize="16"/>

                    <StackPanel Spacing="5"
                              ToolTip.Tip="{loc:Tr WebServerUrlTooltip}">
                        <TextBlock Text="{loc:Tr WebServerUrl}"/>
                        <TextBox Text="{Binding WebServerUrl}" Watermark="http://localhost:9696"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Download Settings -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Tr DownloadSettings}" FontWeight="SemiBold" FontSize="16"/>

                    <CheckBox IsChecked="{Binding YtdlpGlobalPath}" Content="{loc:Tr YtdlpPathGlobalLabel}"
                              ToolTip.Tip="{loc:Tr YtdlpPathGlobalTooltip}"/>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <CheckBox IsChecked="{Binding YtdlUseCookies}" Content="{loc:Tr UseYouTubeCookies}"
                                  ToolTip.Tip="{loc:Tr UseYouTubeCookiesTooltip}"/>
                        <TextBlock Text="{Binding CookieStatus}" VerticalAlignment="Center" Foreground="#81C784" FontStyle="Italic"/>
                    </StackPanel>
                    <CheckBox IsChecked="{Binding YtdlAutoUpdate}" Content="{loc:Tr AutoUpdateUtils}"
                              ToolTip.Tip="{loc:Tr AutoUpdateUtilsTooltip}"/>

                    <StackPanel Spacing="5"
                              ToolTip.Tip="{loc:Tr AdditionalYtdlpArgsTooltip}">
                        <TextBlock Text="{loc:Tr AdditionalYtdlpArgs}"/>
                        <TextBox Text="{Binding YtdlAdditionalArgs}" Watermark="{loc:Tr OptionalArguments}"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                              ToolTip.Tip="{loc:Tr PreferredDubLanguageTooltip}">
                        <TextBlock Text="{loc:Tr PreferredDubLanguage}"/>
                        <TextBox Text="{Binding YtdlDubLanguage}" Watermark="{loc:Tr LeaveEmptyForOriginal}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Cache Settings -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Tr CacheSettings}" FontWeight="SemiBold" FontSize="16"/>

                    <StackPanel Spacing="5"
                              ToolTip.Tip="{loc:Tr CachePathTooltip}">
                        <TextBlock Text="{loc:Tr CachePathLabel}"/>
                        <TextBox Text="{Binding CachedAssetPath}" Watermark="CachedAssets"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                              ToolTip.Tip="{loc:Tr MaxCacheSizeTooltip}">
                        <TextBlock Text="{loc:Tr MaxCacheSizeLabel}"/>
                        <NumericUpDown Value="{Binding CacheMaxSizeInGb}" Minimum="0" Maximum="10000" Increment="1" FormatString="0.#"/>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding CacheYouTube}" Content="{loc:Tr CacheYouTubeVideos}"
                              ToolTip.Tip="{loc:Tr CacheYouTubeTooltip}"/>

                    <StackPanel Spacing="5" Margin="30,0,0,0" IsVisible="{Binding CacheYouTube}">
                        <StackPanel Spacing="5"
                                  ToolTip.Tip="{loc:Tr MaxYouTubeResolutionTooltip}">
                            <TextBlock Text="{loc:Tr MaxYouTubeResolution}"/>
                            <ComboBox ItemsSource="{Binding ResolutionOptions}" SelectedItem="{Binding CacheYouTubeMaxResolution}"/>
                        </StackPanel>

                        <StackPanel Spacing="5"
                                  ToolTip.Tip="{loc:Tr MaxVideoLengthTooltip}">
                            <TextBlock Text="{loc:Tr MaxVideoLength}"/>
                            <NumericUpDown Value="{Binding CacheYouTubeMaxLength}" Minimum="1" Maximum="600" Increment="10"/>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding CachePyPyDance}" Content="{loc:Tr CachePyPyDanceVideos}"
                              ToolTip.Tip="{loc:Tr CachePyPyDanceTooltip}"/>
                    <CheckBox IsChecked="{Binding CacheVRDancing}" Content="{loc:Tr CacheVRDancingVideos}"
                              ToolTip.Tip="{loc:Tr CacheVRDancingTooltip}"/>
                    <CheckBox IsChecked="{Binding CacheOnly}" Content="{loc:Tr OnlyServeCachedVideos}"
                              ToolTip.Tip="{loc:Tr OnlyServeCachedTooltip}"/>

                    <StackPanel Spacing="5"
                              ToolTip.Tip="{loc:Tr MaxConcurrentDownloadsTooltip}">
                        <TextBlock Text="{loc:Tr MaxConcurrentDownloads}"/>
                        <NumericUpDown Value="{Binding MaxConcurrentDownloads}" Minimum="1" Maximum="8" Increment="1"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Eviction Protection (only relevant when max cache size is set) -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20"
                    IsVisible="{Binding CacheMaxSizeInGb, Converter={x:Static vm:GreaterThanZeroConverter.Instance}}">
                <StackPanel Spacing="15">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr EvictionProtection}" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="{loc:Tr EvictionProtectionDesc}" Foreground="#888" FontSize="12"/>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding EvictionProtectYouTube}" Content="{loc:Tr ProtectYouTube}"
                              ToolTip.Tip="{loc:Tr ProtectYouTubeTooltip}"/>
                    <CheckBox IsChecked="{Binding EvictionProtectPyPyDance}" Content="{loc:Tr ProtectPyPyDance}"
                              ToolTip.Tip="{loc:Tr ProtectPyPyDanceTooltip}"/>
                    <CheckBox IsChecked="{Binding EvictionProtectVRDancing}" Content="{loc:Tr ProtectVRDancing}"
                              ToolTip.Tip="{loc:Tr ProtectVRDancingTooltip}"/>
                    <CheckBox IsChecked="{Binding EvictionProtectCustomDomains}" Content="{loc:Tr ProtectCustomDomains}"
                              ToolTip.Tip="{loc:Tr ProtectCustomDomainsTooltip}"/>
                </StackPanel>
            </Border>

            <!-- Custom Domains -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr CustomDomainCaching}" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="{loc:Tr CustomDomainCachingDesc}" Foreground="#888" FontSize="12"/>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding CacheCustomDomainsEnabled}" Content="{loc:Tr EnableCustomDomainCaching}"
                              ToolTip.Tip="{loc:Tr EnableCustomDomainCachingTooltip}"/>

                    <StackPanel Spacing="15" IsVisible="{Binding CacheCustomDomainsEnabled}">
                        <StackPanel>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="{loc:Tr DomainsToCache}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Command="{Binding AddCacheCustomDomainCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                        <TextBlock Text="{loc:Tr AddDomain}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Text="{loc:Tr DomainsToCacheDesc}" Foreground="#888" FontSize="12"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding CacheCustomDomains}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:EditableString">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                                        <TextBox Grid.Column="0" Text="{Binding Value}" Watermark="example.com"/>
                                        <Button Grid.Column="1" Margin="5,0,0,0"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveCacheCustomDomainCommand}"
                                                CommandParameter="{Binding}">
                                            <mi:MaterialIcon Kind="Delete" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Clear Cache on Exit -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr ClearCacheOnExit}" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="{loc:Tr ClearCacheOnExitDesc}" Foreground="#888" FontSize="12"/>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding ClearYouTubeCacheOnExit}" Content="{loc:Tr ClearYouTubeCacheOnExit}"
                              ToolTip.Tip="{loc:Tr ClearYouTubeCacheOnExitTooltip}"/>
                    <CheckBox IsChecked="{Binding ClearPyPyDanceCacheOnExit}" Content="{loc:Tr ClearPyPyDanceCacheOnExit}"
                              ToolTip.Tip="{loc:Tr ClearPyPyDanceCacheOnExitTooltip}"/>
                    <CheckBox IsChecked="{Binding ClearVRDancingCacheOnExit}" Content="{loc:Tr ClearVRDancingCacheOnExit}"
                              ToolTip.Tip="{loc:Tr ClearVRDancingCacheOnExitTooltip}"/>

                    <StackPanel Spacing="10" IsVisible="{Binding CacheCustomDomainsEnabled}" Margin="0,10,0,0">
                        <StackPanel>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="{loc:Tr CustomDomainsToClearOnExit}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Command="{Binding AddClearCustomDomainOnExitCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                        <TextBlock Text="{loc:Tr Add}"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Text="{loc:Tr CustomDomainsToClearOnExitDesc}" Foreground="#888" FontSize="12"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding ClearCustomDomainsOnExit}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:EditableString">
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                                        <TextBox Grid.Column="0" Text="{Binding Value}" Watermark="example.com"/>
                                        <Button Grid.Column="1" Margin="5,0,0,0"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveClearCustomDomainOnExitCommand}"
                                                CommandParameter="{Binding}">
                                            <mi:MaterialIcon Kind="Delete" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Game Patching -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Tr GamePatching}" FontWeight="SemiBold" FontSize="16"/>

                    <CheckBox IsChecked="{Binding PatchVRC}" Content="{loc:Tr PatchVRChat}"
                              ToolTip.Tip="{loc:Tr PatchVRChatTooltip}"/>
                    <CheckBox IsChecked="{Binding PatchResonite}" Content="{loc:Tr PatchResonite}"
                              ToolTip.Tip="{loc:Tr PatchResoniteTooltip}"/>
                </StackPanel>
            </Border>

            <!-- Updates & Startup -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="{loc:Tr UpdatesAndStartup}" FontWeight="SemiBold" FontSize="16"/>

                    <CheckBox IsChecked="{Binding AutoUpdate}" Content="{loc:Tr AutoUpdateVRCVideoCacher}"
                              ToolTip.Tip="{loc:Tr AutoUpdateVRCVideoCacherTooltip}"/>
                    <CheckBox IsChecked="{Binding VrcxAutoStart}"
                              Content="{loc:Tr StartWithVRCX}"
                              IsVisible="{Binding IsVrcxInstalled}"
                              ToolTip.Tip="{loc:Tr StartWithVRCXTooltip}"/>
                    <CheckBox IsChecked="{Binding SteamVrAutoStart}"
                              Content="{loc:Tr StartWithSteamVR}"
                              IsVisible="{Binding IsSteamVrInstalled}"
                              ToolTip.Tip="{loc:Tr StartWithSteamVRTooltip}"/>
                </StackPanel>
            </Border>

            <!-- Advanced Settings -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel>
                        <TextBlock Text="{loc:Tr AdvancedSettings}" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="{loc:Tr AdvancedSettingsDesc}" Foreground="#f0ad4e" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Spacing="5"
                              ToolTip.Tip="{loc:Tr YtdlpArgsOverrideTooltip}">
                        <TextBlock Text="{loc:Tr YtdlpArgsOverride}"/>
                        <TextBox Text="{Binding YtdlArgsOverride}" Watermark="{loc:Tr LeaveEmptyForAdditionalArgs}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Pre-Cache URLs -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="{loc:Tr PreCacheUrls}" FontWeight="SemiBold" FontSize="16"/>
                            <Button Grid.Column="1" Command="{Binding AddPreCacheUrlCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                    <TextBlock Text="{loc:Tr Add}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <TextBlock Text="{loc:Tr PreCacheUrlsDesc}" Foreground="#888" FontSize="12"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding PreCacheUrls}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:EditableString">
                                <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                                    <TextBox Grid.Column="0" Text="{Binding Value}" Watermark="https://youtube.com/watch?v=..."/>
                                    <Button Grid.Column="1" Margin="5,0,0,0"
                                            Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemovePreCacheUrlCommand}"
                                            CommandParameter="{Binding}">
                                        <mi:MaterialIcon Kind="Delete" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Blocked URLs -->
            <Border Background="#2d2d2d" CornerRadius="8" Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="{loc:Tr BlockedUrls}" FontWeight="SemiBold" FontSize="16"/>
                            <Button Grid.Column="1" Command="{Binding AddBlockedUrlCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <mi:MaterialIcon Kind="Plus" Width="16" Height="16"/>
                                <TextBlock Text="{loc:Tr Add}"/>
                            </StackPanel>
                        </Button>
                        </Grid>
                        <TextBlock Text="{loc:Tr BlockedUrlsDesc}" Foreground="#888" FontSize="12"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding BlockedUrls}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:EditableString">
                                <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                                    <TextBox Grid.Column="0" Text="{Binding Value}"/>
                                    <Button Grid.Column="1" Margin="5,0,0,0"
                                            Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveBlockedUrlCommand}"
                                            CommandParameter="{Binding}">
                                        <mi:MaterialIcon Kind="Delete" Width="16" Height="16"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Spacing="5" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Tr BlockedUrlRedirect}" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{loc:Tr BlockedUrlRedirectDesc}" Foreground="#888" FontSize="12"/>
                        </StackPanel>
                        <TextBox Text="{Binding BlockRedirect}" Watermark="{loc:Tr RedirectUrl}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#1DB954"/>
        </Style>
    </UserControl.Styles>
</UserControl>
